{
  "name": "ukrainewar",
  "version": "1.2.3",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npx tsx scripts/prebuild-viina.ts && npx tsx scripts/prebuild-alliance.ts && npx tsx scripts/prebuild-territory-dates.ts && next build --webpack",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "build:worker": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:cron": "cd workers/data-refresh && npx wrangler deploy --config wrangler.toml",
    "data:kiel": "node scripts/process-kiel.mjs",
    "data:acled": "node scripts/process-acled-hdx.mjs",
    "data:viina": "node scripts/process-viina.mjs",
    "data:update": "node scripts/process-kiel.mjs && node scripts/process-acled-hdx.mjs && node scripts/process-viina.mjs",
    "cache:warm": "node scripts/warm-cache.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "maplibre-gl": "5.21.1",
    "next": "16.2.1",
    "nuqs": "^2.8.9",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "shadcn": "4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@opennextjs/cloudflare": "1.18.0",
    "@tailwindcss/postcss": "4.2.2",
    "@turf/turf": "^7.3.4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.1",
    "exceljs": "^4.4.0",
    "husky": "^9.1.7",
    "tailwindcss": "4.2.2",
    "topojson-client": "^3.1.0",
    "typescript": "^6",
    "world-atlas": "^2.0.2",
    "wrangler": "4.80.0"
  },
  "license": "AGPL-3.0-or-later",
  "author": "David Engel (https://github.com/engelde)",
  "repository": {
    "type": "git",
    "url": "https://github.com/engelde/ukrainewar.git"
  },
  "homepage": "https://ukrainewar.app"
}
